# Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://phismail:phismail_secret@localhost:5432/phismail
DATABASE_ECHO=false

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Application
# =============================================================================
APP_NAME=PhisMail
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-in-production-use-a-random-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# File Upload
# =============================================================================
MAX_UPLOAD_SIZE_MB=5
STORAGE_PATH=./storage
ALLOWED_MIME_TYPES=message/rfc822,application/octet-stream

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_PER_HOUR=100

# =============================================================================
# Threat Intelligence API Keys
# =============================================================================
PHISHTANK_API_KEY=
URLHAUS_AUTH_KEY=
OPENPHISH_FEED_URL=https://openphish.com/feed.txt

# =============================================================================
# Cache TTL (seconds)
# =============================================================================
CACHE_TTL_DOMAIN_INTEL=86400
CACHE_TTL_THREAT_LOOKUP=86400
CACHE_TTL_DNS_RECORDS=86400

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# ML
# =============================================================================
ML_MODEL_PATH=./ml_models
ML_RANDOM_SEED=42

# =============================================================================
# Authentication
# =============================================================================
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
